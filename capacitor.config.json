{
  "appId": "com.welsonslee.matsci.calculator",
  "appName": "MatSci Calculator",
  "webDir": "dist",
  "webResourcesDir": "resources",
  "server": {
    "androidScheme": "https",
    "iosScheme": "https"
  },
  "ios": {
    "contentInset": "automatic",
    "allowsLinkPreview": false,
    "scrollEnabled": true,
    "initialOrientation": "portrait"
  },
  "plugins": {
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#F4F7FB"
    },
    "Keyboard": {
      "resize": "none",
      "resizeOnFullScreen": true
    },
    "SafeArea": {
      "enabled": true
    }
  }
}
